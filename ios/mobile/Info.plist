	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Ứng dụng cần quyền truy cập vị trí của bạn để hiển thị địa chỉ giao hàng, tìm kiếm cửa hàng gần bạn và cải thiện trải nghiệm sử dụng.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Ứng dụng cần quyền microphone để thực hiện cuộc gọi thoại, ghi âm và quay video có âm thanh.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Ứng dụng cần quyền để lưu ảnh và video vào thư viện của bạn.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Ứng dụng cần quyền truy cập thư viện ảnh để bạn có thể chọn ảnh và video từ thư viện của bạn.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Ứng dụng cần quyền nhận dạng giọng nói để hỗ trợ tìm kiếm bằng giọng nói.</string>
